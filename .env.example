# Environment Variables Template
# Copy this file to .env and update with your actual values
# The .env file is gitignored and won't be committed to GitHub

# ============================================
# Create React App Performance Settings
# ============================================

# Skip preflight checks (speeds up startup)
SKIP_PREFLIGHT_CHECK=true

# Don't treat ESLint warnings as errors in development
ESLINT_NO_DEV_ERRORS=true

# Allow TypeScript compilation errors in development
TSC_COMPILE_ON_ERROR=true

# ============================================
# API Keys & Secrets (if needed in future)
# ============================================

# Example: API_KEY=your_api_key_here
# Example: DATABASE_URL=your_database_url_here
# Example: SECRET_KEY=your_secret_key_here

# ============================================
# Feature Flags (if needed)
# ============================================

# Example: REACT_APP_ENABLE_FEATURE_X=true
# Example: REACT_APP_API_URL=https://api.example.com

# ============================================
# Build Settings
# ============================================

# Example: GENERATE_SOURCEMAP=false
# Example: INLINE_RUNTIME_CHUNK=false
